{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://satis.local/schemas/planner/logical_plan_ir.schema.json",
  "title": "LogicalPlanIR",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "logical_plan_version",
    "goal",
    "steps"
  ],
  "properties": {
    "logical_plan_version": {
      "type": "integer",
      "minimum": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "planner_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/logical_step"
      }
    }
  },
  "$defs": {
    "logical_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_key",
        "intent",
        "inputs",
        "outputs"
      ],
      "properties": {
        "step_key": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/output_port"
          }
        },
        "supplementary_info": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "input_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_step",
        "port"
      ],
      "properties": {
        "from_step": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "port": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "consumer_hints": {
          "$ref": "handoff.schema.json#/$defs/consumer_hints"
        },
        "supplementary_info": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "output_port": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "port",
        "kind"
      ],
      "properties": {
        "port": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "kind": {
          "type": "string",
          "enum": ["file_ref", "text_blob", "json"]
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
